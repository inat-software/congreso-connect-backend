# ============================================
# Configuracion de entorno para Congreso Connect API
# Copiar este archivo como .env y completar los valores
# ============================================

# --- Seguridad ---
SECRET_KEY=cambiar-por-una-clave-segura-en-produccion
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de datos ---
# Opciones para DATABASE_ENGINE: postgresql, mysql, sqlite3
DATABASE_ENGINE=postgresql
DATABASE_NAME=congreso-connect
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432

# --- CORS ---
# Lista separada por comas de origenes permitidos
CORS_ALLOWED_ORIGINS=http://localhost:4200
CORS_ALLOW_CREDENTIALS=True

# --- Cache / Channels / Celery (Redis) ---
USE_REDIS=False
REDIS_URL=redis://127.0.0.1:6379/1

# --- Internacionalizacion ---
LANGUAGE_CODE=en-us
TIME_ZONE=UTC

# --- REST Framework ---
PAGE_SIZE=20

# --- JWT ---
JWT_ACCESS_LIFETIME_MINUTES=30
JWT_REFRESH_LIFETIME_DAYS=7

# --- Correo (envio del QR al asistente al registrarse) ---
# Dev: backend de consola (imprime el correo). Prod: usar el backend SMTP y
# completar los datos del emisor.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Muchik 2026 <no-reply@muchik.pe>
